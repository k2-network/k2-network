# Runtime only — binary được build sẵn trên máy local
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy pre-built binary
COPY k2-web-server-binary ./k2-web-server

RUN chmod +x ./k2-web-server && mkdir -p /app/data

EXPOSE 3001

CMD ["./k2-web-server"]
