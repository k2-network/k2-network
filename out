              </span>
              <span className="metric-value">{broadcastCount}</span>
            </div>
          </div>

          {/* Slim Progress Line at Bottom - CSS animated */}
          {phase !== 'found' && (
            <div className="compact-progress-line">
              <div className="compact-progress-fill" />
            </div>
