/// Share a file and return the ticket string
#[tauri::command]
async fn share_file(path: String, state: State<'_, AppState>) -> Result<String, String> {
    let node = {
        let guard = state.node.lock().unwrap();
        guard.clone().ok_or("Node not initialized")?
