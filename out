    topic: boolean;
    selection: boolean;
    action: boolean;
    title: boolean;
    description: boolean;
    priceRange: boolean;
    location: boolean;
    condition: boolean;
    // Topic-specific
    brand?: boolean;
    fileFormat?: boolean;
    deadline?: boolean;
    [key: string]: boolean | undefined;
}

// Props for DynamicRequestForm component
