                broadcasts++;
                setBroadcastCount(broadcasts);

                console.log(`[DiscoveryView] 📡 Attempting broadcast #${broadcasts}...`);
                try {
                  // Tauri auto-converts camelCase to snake_case for Rust
                  await invoke('broadcast_offer', { topic, formData });
