{
    "$schema": "../gen/schemas/mobile-schema.json",
    "identifier": "mobile",
    "description": "Capability for mobile (Android/iOS)",
    "windows": [
        "main"
    ],
    "platforms": [
        "android",
        "iOS"
    ],
    "permissions": [
        "core:default",
        "opener:default",
        "dialog:default",
        "dialog:allow-open",
        "dialog:allow-save",
        "barcode-scanner:default",
        "barcode-scanner:allow-scan",
        "barcode-scanner:allow-cancel",
        "barcode-scanner:allow-check-permissions",
        "barcode-scanner:allow-request-permissions",
        "fs:default",
        "fs:allow-read",
        "fs:allow-write"
    ]
}