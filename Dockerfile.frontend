# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

COPY k2-app-web/package*.json ./
RUN npm ci

COPY k2-app-web ./
RUN npm run build

# Runtime stage — serve static via nginx
FROM nginx:alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.frontend.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
