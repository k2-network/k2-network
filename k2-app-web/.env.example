# API server URL (empty = use Vite proxy in dev; set to https://... in production)
VITE_API_URL=

# WebSocket URL (empty = use Vite proxy in dev)
VITE_WS_URL=

# Groq API key
VITE_GROQ_API_KEY=

# Groq model settings
VITE_GROQ_MODEL=llama-3.3-70b-versatile
VITE_GROQ_SMALL_MODEL=llama-3.1-8b-instant
VITE_GROQ_BASE_URL=https://api.groq.com/openai/v1
